# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnpm-store
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# Local development
.env
.env*.local

# Next.js
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Local debug/scratch artifacts (never commit)
/current_config.json
/new_config.json
/new_config_true.json
/test_save.json
/config/*.json
*.tsclear

# Ignore custom user-uploaded icons and backgrounds
/public/icons/*
/public/backgrounds/*
/public/uploads/*
/config/services.yml

# Keep directory structure
!/public/icons/.gitkeep
!/public/backgrounds/.gitkeep
!/public/uploads/.gitkeep
!/config/.gitkeep

